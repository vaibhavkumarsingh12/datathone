# (src/, app/, deploy/) never opens this folder. See README → "The sealed exam".

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Environments
.venv/
venv/

# Local checkpoint archives (the restore guide is tracked, the zips are not)
_backups/*.zip
